{
  "permissions": {
    "allow": [
      "Read:*",
      "Bash:git *",
      "Write:*",
      "Edit:*"
    ],
    "deny": [
      "Read:.env*",
      "Bash:sudo *",
      "Bash:rm -rf *",
      "Bash:rm -r *",
      "Bash:rm -f *",
      "Bash:shred *",
      "Bash:curl *",
      "Bash:wget *",
      "Bash:nc *",
      "Bash:ncat *",
      "Bash:netcat *",
      "Bash:ssh *",
      "Bash:scp *",
      "Bash:sftp *",
      "Bash:ftp *",
      "Bash:rsync *",
      "Bash:telnet *",
      "Bash:mysql *",
      "Bash:psql *",
      "Bash:sqlite3 *",
      "Bash:mongosh *",
      "Bash:redis-cli *",
      "Bash:git push --force*",
      "Bash:git push -f *",
      "Bash:git reset --hard*",
      "Bash:git clean -f*",
      "Bash:python -c *",
      "Bash:python3 -c *",
      "Bash:node -e *",
      "Bash:perl -e *",
      "Bash:ruby -e *",
      "Read:*password*",
      "Read:*secret*",
      "Read:*credential*",
      "Read:*private_key*",
      "Read:*id_rsa*",
      "Read:*id_ed25519*",
      "Read:*auth_token*",
      "Read:*.pem",
      "Read:*.key",
      "Read:*.p12",
      "Read:*.pfx"
    ],
    "ask": [
      "Bash:rm *"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/claude/.claude/hooks/audit-log.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/claude/.claude/hooks/pii-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/claude/.claude/hooks/auto-push.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
