{
  "permissions": {
    "allow": [
      "Read:*",
      "Bash:git:*",
      "Write:*",
      "Edit:*"
    ],
    "deny": [
      "Read:.env*",
      "Bash:sudo:*",
      "Bash:rm -rf /:*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-bash-check.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
